{
    "name": "logos-lang",
    "displayName": "Logos (Orthodox)",
    "description": "Liturgical programming language support for Logos (.lg)",
    "version": "1.0.0",
    "publisher": "Theophilus",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "main": "./dist/extension.js",
    "scripts": {
        "compile": "tsc -p .",
        "package": "npm run compile && vsce package",
        "test:extension-host": "npm run compile && node ./dist/test/runTest.js"
    },
    "dependencies": {
        "vscode-languageserver": "^9.0.1",
        "vscode-languageclient": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12"
    },
    "devDependencies": {
        "@types/node": "^18.19.0",
        "@types/mocha": "^10.0.10",
        "@types/vscode": "^1.75.0",
        "@vscode/test-electron": "^2.5.2",
        "glob": "^10.4.5",
        "mocha": "^10.8.2",
        "typescript": "^5.3.3"
    },
    "contributes": {
        "languages": [{
            "id": "logos",
            "aliases": ["Logos", "logos"],
            "extensions": [".lg"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "logos",
            "scopeName": "source.logos",
            "path": "./syntaxes/logos.tmLanguage.json"
        }]
    }
}
